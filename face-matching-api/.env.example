# Bind
HOST=0.0.0.0
PORT=8050

# Default backend: opencv | mediapipe | retinaface | mtcnn | face_recognition
FACE_METHOD=opencv

# DeepFace model name (VGG-Face, Facenet, OpenFace, DeepID, Dlib, ArcFace, SFace, GhostFaceNet)
DEEPFACE_MODEL=Facenet
DEEPFACE_DISTANCE_METRIC=cosine

# Only for face_recognition (dlib) method — max L2 between encodings
FACE_RECOGNITION_TOLERANCE=0.6

LOG_DETAIL=true
