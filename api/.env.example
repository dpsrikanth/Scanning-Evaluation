# Copy to .env and adjust. See api/src/config/env.js for all options.
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
JWT_SECRET=change-me-in-production

SCAN_DB_HOST=localhost
SCAN_DB_PORT=3307
SCAN_DB_USER=root
# Must match the MySQL user (empty = "using password: NO" and login will return 503)
SCAN_DB_PASSWORD=
SCAN_DB_NAME=ScanningDB

EVAL_DB_HOST=localhost
EVAL_DB_PORT=3307
EVAL_DB_USER=root
# Must match the MySQL user (empty causes DB errors on /api/auth/login)
EVAL_DB_PASSWORD=
EVAL_DB_NAME=EvaluationDB

# Python face-matching service (evaluator login). Default: http://127.0.0.1:8050
# Use at least 60000–120000 ms locally; first /facematch call can exceed 12s while models load.
# FACE_MATCHING_API_URL=http://127.0.0.1:8050
# FACE_MATCHING_TIMEOUT_MS=120000
