<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <!--
      ScannerApp configuration.

      Override the defaults below for each workstation by editing this file
      (deployed beside ScannerApp.exe as ScannerApp.exe.config). The application
      reads these values via ScannerApp.Utils.AppConfig.
    -->

    <!-- Main HTTP API for auth, templates, booklet uploads, etc. -->
    <add key="ApiBaseUrl"            value="http://localhost:4000" />

    <!-- Optional server-side barcode decoder (zxing-wasm) URL. -->
    <add key="BarcodeApiBaseUrl"     value="http://localhost:8787" />

    <!-- Whether the desktop should use the server barcode API by default. -->
    <add key="UseServerBarcode"      value="false" />

    <!-- Default folder to use for scanned booklets and the local upload queue. -->
    <add key="DefaultLocalStoragePath" value="C:\ScanOutput" />

    <!--
      Optional: write a copy of every failed pageserialno crop to this folder so
      the unread barcode can be inspected later. Leave blank to disable.
      Example: C:\ScanOutput\_barcode_failures
    -->    
		<add key="BarcodeFailureCropDir" value="C:\ScanOutput\_barcode_failures" />
  </appSettings>
</configuration>
